function seedUsers(PDO $pdo): void
{
    echo "Seeding users...\n";

    try {
        $pdo->query('SELECT 1 FROM users LIMIT 1');
    } catch (PDOException $e) {
        die("Error: The 'users' table does not exist. Run migrations first.\n");
    }

    $stmt = $pdo->prepare("
        INSERT INTO users (name, email, password_hash, role)
        VALUES (?, ?, ?, ?)
    ");

    $users = [
        ['Admin User', 'admin@phpspa.com', 'password', 'admin'],
        ['Demo User', 'user@phpspa.com', 'password', 'user']
    ];

    $count = 0;
    foreach ($users as $u) {
        // Skip if exists
        $check = $pdo->prepare('SELECT id FROM users WHERE email = ?');
        $check->execute([$u[1]]);
        if (!$check->fetch()) {
            $stmt->execute([
                $u[0],
                $u[1],
                password_hash($u[2], PASSWORD_BCRYPT, ['cost' => 12]),
                $u[3]
            ]);
            $count++;
        }
    }

    echo "Seeded {$count} users successfully (Passwords are 'password').\n";
}
