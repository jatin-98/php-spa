#!/usr/bin/env php
<?php

/**
 * PhpSPA CLI Tool
 *
 * Commands:
 *   php phpspa migrate           Run all pending migrations
 *   php phpspa migrate:rollback  Roll back the last batch of migrations
 *   php phpspa migrate:fresh     Drop everything and re-run all migrations
 *   php phpspa db:seed           Run ALL seeders (in alphabetical order)
 *   php phpspa db:seed <Name>    Run a specific seeder, e.g. db:seed Posts
 */

define('BASE_PATH', __DIR__);

require_once BASE_PATH . '/app/Core/Database.php';
use Core\Database;

if (php_sapi_name() !== 'cli') {
    die("This script can only be run from the command line.\n");
}

$command = $argv[1] ?? 'help';
$arg     = $argv[2] ?? null;  // optional argument, e.g. the seeder name

try {
    $pdo = Database::getInstance();
} catch (Exception $e) {
    die("Error connecting to database: " . $e->getMessage() . "\n");
}

switch ($command) {
    case 'migrate':
        migrate($pdo);
        break;
    case 'migrate:rollback':
        rollback($pdo);
        break;
    case 'migrate:fresh':
        fresh($pdo);
        break;
    case 'db:seed':
        runSeeders($pdo, $arg);
        break;
    case 'help':
    default:
        printHelp();
        break;
}

// ── Help ──────────────────────────────────────────────────────────────────────

function printHelp(): void
{
    echo "\n";
    echo "  \033[1;35mPhpSPA CLI\033[0m\n\n";
    echo "  \033[0;33mMigrations\033[0m\n";
    echo "    \033[0;32mmigrate\033[0m               Run all pending migrations\n";
    echo "    \033[0;32mmigrate:rollback\033[0m      Roll back the last batch of migrations\n";
    echo "    \033[0;32mmigrate:fresh\033[0m         Drop all tables and re-run all migrations\n";
    echo "\n";
    echo "  \033[0;33mSeeders\033[0m\n";
    echo "    \033[0;32mdb:seed\033[0m               Run all seeders in database/seeders/\n";
    echo "    \033[0;32mdb:seed <Name>\033[0m        Run a specific seeder (e.g. db:seed Posts)\n";
    echo "\n";
    echo "  Seeder files live in \033[0;36mdatabase/seeders/<Name>Seeder.php\033[0m\n";
    echo "  Each file must define a class implementing SeederInterface.\n";
    echo "\n";
}

// ── Seeder Runner ─────────────────────────────────────────────────────────────

/**
 * Discover and run seeders from database/seeders/.
 *
 * If $seederName is provided (e.g. "Posts"), only "<Name>Seeder.php" is run.
 * Otherwise all *Seeder.php files are loaded and run in alphabetical order.
 */
function runSeeders(PDO $pdo, ?string $seederName): void
{
    $dir = BASE_PATH . '/database/seeders';

    if (!is_dir($dir)) {
        die("Error: Seeders directory not found at {$dir}\n");
    }

    // Require the interface so seeder classes can implement it
    require_once $dir . '/SeederInterface.php';

    if ($seederName !== null) {
        // Run a specific seeder
        $file  = $dir . '/' . $seederName . 'Seeder.php';
        $class = $seederName . 'Seeder';

        if (!file_exists($file)) {
            die("Error: Seeder file not found: {$file}\n");
        }

        require_once $file;

        if (!class_exists($class)) {
            die("Error: Class '{$class}' not found in {$file}\n");
        }

        $seeder = new $class();
        $seeder->run($pdo);
    } else {
        // Run all seeders alphabetically
        $files = glob($dir . '/*Seeder.php');
        sort($files);

        if (empty($files)) {
            echo "No seeders found in {$dir}\n";
            return;
        }

        foreach ($files as $file) {
            $class = basename($file, '.php');

            // Skip the interface file itself
            if ($class === 'SeederInterface') {
                continue;
            }

            require_once $file;

            if (!class_exists($class)) {
                echo "Warning: Class '{$class}' not found in {$file} — skipping.\n";
                continue;
            }

            $seeder = new $class();
            $seeder->run($pdo);
        }
    }
}

// ── Migration Commands ────────────────────────────────────────────────────────

function getMigrationFiles(string $direction): array
{
    $dir = BASE_PATH . '/database/migrations';
    if (!is_dir($dir)) {
        return [];
    }

    $files = glob("{$dir}/*.{$direction}.sql");
    sort($files);
    return $files;
}

function getRanMigrations(PDO $pdo): array
{
    return $pdo->query('SELECT migration FROM migrations')->fetchAll(PDO::FETCH_COLUMN);
}

function getNextBatchNumber(PDO $pdo): int
{
    $max = (int) $pdo->query('SELECT MAX(batch) FROM migrations')->fetchColumn();
    return $max + 1;
}

function migrate(PDO $pdo): void
{
    echo "Running migrations...\n";

    $ran   = getRanMigrations($pdo);
    $files = getMigrationFiles('up');
    $batch = getNextBatchNumber($pdo);

    $count = 0;

    foreach ($files as $file) {
        $name = basename($file, '.up.sql');

        if (in_array($name, $ran)) {
            continue;
        }

        echo "Migrating: {$name}\n";

        $sql = file_get_contents($file);
        $pdo->exec($sql);

        $stmt = $pdo->prepare('INSERT INTO migrations (migration, batch) VALUES (?, ?)');
        $stmt->execute([$name, $batch]);

        echo "Migrated:  {$name}\n";
        $count++;
    }

    if ($count === 0) {
        echo "Nothing to migrate.\n";
    }
}

function rollback(PDO $pdo): void
{
    echo "Rolling back migrations...\n";

    $max = (int) $pdo->query('SELECT MAX(batch) FROM migrations')->fetchColumn();

    if ($max === 0) {
        echo "Nothing to rollback.\n";
        return;
    }

    $stmt = $pdo->prepare('SELECT migration FROM migrations WHERE batch = ? ORDER BY id DESC');
    $stmt->execute([$max]);
    $migrationsToRollback = $stmt->fetchAll(PDO::FETCH_COLUMN);

    $files = getMigrationFiles('down');
    $downFiles = [];
    foreach ($files as $file) {
        $name = basename($file, '.down.sql');
        $downFiles[$name] = $file;
    }

    $count = 0;

    foreach ($migrationsToRollback as $name) {
        if (!isset($downFiles[$name])) {
            echo "Warning: Down migration file not found for {$name}\n";
            continue;
        }

        echo "Rolling back: {$name}\n";

        $sql = file_get_contents($downFiles[$name]);
        $pdo->exec($sql);

        $delStmt = $pdo->prepare('DELETE FROM migrations WHERE migration = ?');
        $delStmt->execute([$name]);

        echo "Rolled back:  {$name}\n";
        $count++;
    }

    if ($count === 0) {
        echo "Nothing to rollback.\n";
    }
}

function fresh(PDO $pdo): void
{
    echo "Dropping all tables...\n";

    $tables = $pdo->query("SELECT name FROM sqlite_master WHERE type='table' AND name != 'sqlite_sequence'")->fetchAll(PDO::FETCH_COLUMN);

    foreach ($tables as $table) {
        $pdo->exec("DROP TABLE {$table}");
    }

    // Recreate the migrations tracking table
    $pdo->exec("
        CREATE TABLE IF NOT EXISTS migrations (
            id        INTEGER PRIMARY KEY AUTOINCREMENT,
            migration TEXT NOT NULL UNIQUE,
            batch     INTEGER NOT NULL,
            run_at    TEXT NOT NULL DEFAULT (datetime('now'))
        )
    ");

    echo "Dropped all tables successfully.\n";

    migrate($pdo);
}
