#!/usr/bin/env php
<?php

/**
 * PhpSPA CLI Tool
 *
 * Commands:
 *   php phpspa migrate           Run all pending migrations
 *   php phpspa migrate:rollback  Roll back the last batch of migrations
 *   php phpspa migrate:fresh     Drop everything and re-run all migrations
 *   php phpspa db:seed           Seed dummy data
 *   php phpspa user:seed         Seed a demo user and admin user
 */

define('BASE_PATH', __DIR__);

require_once BASE_PATH . '/app/Core/Database.php';
use Core\Database;

if (php_sapi_name() !== 'cli') {
    die("This script can only be run from the command line.\n");
}

$command = $argv[1] ?? 'help';

try {
    $pdo = Database::getInstance();
} catch (Exception $e) {
    die("Error connecting to database.\n");
}

switch ($command) {
    case 'migrate':
        migrate($pdo);
        break;
    case 'migrate:rollback':
        rollback($pdo);
        break;
    case 'migrate:fresh':
        fresh($pdo);
        break;
    case 'db:seed':
        seed($pdo);
        break;
    case 'user:seed':
        seedUsers($pdo);
        break;
    case 'help':
    default:
        echo "PhpSPA CLI\n\n";
        echo "Available commands:\n";
        echo "  migrate           Run all pending migrations\n";
        echo "  migrate:rollback  Roll back the last batch of migrations\n";
        echo "  migrate:fresh     Drop everything and re-run all migrations\n";
        echo "  db:seed           Seed dummy data\n";
        echo "  user:seed         Seed a demo user and admin user\n";
        break;
}

// ── Commands ──────────────────────────────────────────────────────────────────

function getMigrationFiles(string $direction): array
{
    $dir = BASE_PATH . '/database/migrations';
    if (!is_dir($dir)) {
        return [];
    }

    $files = glob("{$dir}/*.{$direction}.sql");
    sort($files);
    return $files;
}

function getRanMigrations(PDO $pdo): array
{
    return $pdo->query('SELECT migration FROM migrations')->fetchAll(PDO::FETCH_COLUMN);
}

function getNextBatchNumber(PDO $pdo): int
{
    $max = (int) $pdo->query('SELECT MAX(batch) FROM migrations')->fetchColumn();
    return $max + 1;
}

function migrate(PDO $pdo): void
{
    echo "Running migrations...\n";

    $ran   = getRanMigrations($pdo);
    $files = getMigrationFiles('up');
    $batch = getNextBatchNumber($pdo);

    $count = 0;

    foreach ($files as $file) {
        $name = basename($file, '.up.sql');

        if (in_array($name, $ran)) {
            continue;
        }

        echo "Migrating: {$name}\n";
        
        $sql = file_get_contents($file);
        $pdo->exec($sql);

        $stmt = $pdo->prepare('INSERT INTO migrations (migration, batch) VALUES (?, ?)');
        $stmt->execute([$name, $batch]);

        echo "Migrated:  {$name}\n";
        $count++;
    }

    if ($count === 0) {
        echo "Nothing to migrate.\n";
    }
}

function rollback(PDO $pdo): void
{
    echo "Rolling back migrations...\n";

    $max = (int) $pdo->query('SELECT MAX(batch) FROM migrations')->fetchColumn();

    if ($max === 0) {
        echo "Nothing to rollback.\n";
        return;
    }

    $stmt = $pdo->prepare('SELECT migration FROM migrations WHERE batch = ? ORDER BY id DESC');
    $stmt->execute([$max]);
    $migrationsToRollback = $stmt->fetchAll(PDO::FETCH_COLUMN);

    $files = getMigrationFiles('down');
    $downFiles = [];
    foreach ($files as $file) {
        $name = basename($file, '.down.sql');
        $downFiles[$name] = $file;
    }

    $count = 0;

    foreach ($migrationsToRollback as $name) {
        if (!isset($downFiles[$name])) {
            echo "Warning: Down migration file not found for {$name}\n";
            continue;
        }

        echo "Rolling back: {$name}\n";

        $sql = file_get_contents($downFiles[$name]);
        $pdo->exec($sql);

        $delStmt = $pdo->prepare('DELETE FROM migrations WHERE migration = ?');
        $delStmt->execute([$name]);

        echo "Rolled back:  {$name}\n";
        $count++;
    }

    if ($count === 0) {
        echo "Nothing to rollback.\n";
    }
}

function fresh(PDO $pdo): void
{
    echo "Dropping all tables...\n";

    // SQLite way to list all tables
    $tables = $pdo->query("SELECT name FROM sqlite_master WHERE type='table' AND name != 'sqlite_sequence'")->fetchAll(PDO::FETCH_COLUMN);
    
    foreach ($tables as $table) {
        $pdo->exec("DROP TABLE {$table}");
    }

    // Ensure migrations table is recreated by re-instantiating the Database singleton logic 
    // actually, it was already created when getInstance was called, but we dropped it.
    // Let's just recreate it.
    $pdo->exec("
        CREATE TABLE IF NOT EXISTS migrations (
            id        INTEGER PRIMARY KEY AUTOINCREMENT,
            migration TEXT NOT NULL UNIQUE,
            batch     INTEGER NOT NULL,
            run_at    TEXT NOT NULL DEFAULT (datetime('now'))
        )
    ");

    echo "Dropped all tables successfully.\n";

    migrate($pdo);
}

